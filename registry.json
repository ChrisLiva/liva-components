{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "liva-components",
  "homepage": "liva-components (local registry — not hosted)",
  "items": [
    {
      "name": "feedback-base-ui",
      "type": "registry:component",
      "title": "Feedback Button (Base UI)",
      "description": "A floating trigger, a compose dialog with report kinds and an optional screenshot, a staged send with a progress bar, and a confirmation — the Base UI skin over a headless core. Bundles its lib helpers; installs nothing under components/ui.",
      "dependencies": [
        "lucide-react",
        "modern-screenshot"
      ],
      "files": [
        {
          "path": "registry/feedback-skin-base-ui/feedback-button.tsx",
          "type": "registry:component",
          "target": "@components/feedback/feedback-button.tsx"
        },
        {
          "path": "registry/feedback-skin-base-ui/feedback-progress.tsx",
          "type": "registry:component",
          "target": "@components/feedback/feedback-progress.tsx"
        },
        {
          "path": "registry/feedback-core/use-feedback.ts",
          "type": "registry:lib",
          "target": "@lib/feedback/use-feedback.ts"
        },
        {
          "path": "registry/feedback-core/feedback-defaults.ts",
          "type": "registry:lib",
          "target": "@lib/feedback/feedback-defaults.ts"
        },
        {
          "path": "registry/screenshot-capture/capture.ts",
          "type": "registry:lib",
          "target": "@lib/feedback/capture.ts"
        },
        {
          "path": "registry/diagnostics/diagnostics.ts",
          "type": "registry:lib",
          "target": "@lib/feedback/diagnostics.ts"
        },
        {
          "path": "registry/scrub/scrub.ts",
          "type": "registry:lib",
          "target": "@lib/feedback/scrub.ts"
        }
      ],
      "meta": {
        "cssSyncedWith": "styles.css — same `lc-` accent block; kept in step by styles-sync.test.ts."
      },
      "css": {
        "@property --lc-accent": {
          "syntax": "\"<color>\"",
          "inherits": "true",
          "initial-value": "oklch(0.65 0.004 290)"
        },
        "@utility lc-accent-frame": {
          "&::after": {
            "content": "\"\"",
            "position": "absolute",
            "inset": "-40px",
            "padding": "40px",
            "border-radius": "calc(var(--lc-frame-radius, 1rem) + 40px)",
            "background": "var(--lc-accent-gradient)",
            "background-origin": "content-box",
            "background-clip": "content-box",
            "mask": "linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0)",
            "mask-composite": "exclude",
            "filter": "blur(13px)",
            "opacity": "0.5",
            "pointer-events": "none"
          },
          "&::before": {
            "content": "\"\"",
            "position": "absolute",
            "inset": "0",
            "border-radius": "inherit",
            "padding": "1.5px",
            "background": "var(--lc-accent-gradient)",
            "mask": "linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0)",
            "mask-composite": "exclude",
            "pointer-events": "none"
          }
        },
        "@utility lc-accent-shift": {
          "transition": "--lc-accent 400ms ease-out",
          "@media (prefers-reduced-motion: reduce)": {
            "transition": "none"
          }
        },
        ":root": {
          "--lc-accent": "var(--foreground)",
          "--lc-accent-gradient": "linear-gradient(135deg, var(--lc-accent), var(--lc-accent))"
        }
      }
    },
    {
      "name": "feedback-antd",
      "type": "registry:component",
      "title": "Feedback Button (antd)",
      "description": "The native antd skin over the same headless core: Modal, Segmented, Input.TextArea, and Progress, with no Tailwind. Bundles its lib helpers; installs nothing under components/ui.",
      "dependencies": [
        "antd",
        "@ant-design/icons",
        "modern-screenshot"
      ],
      "files": [
        {
          "path": "registry/feedback-skin-antd/feedback-button.tsx",
          "type": "registry:component",
          "target": "@components/feedback/feedback-button.tsx"
        },
        {
          "path": "registry/feedback-core/use-feedback.ts",
          "type": "registry:lib",
          "target": "@lib/feedback/use-feedback.ts"
        },
        {
          "path": "registry/feedback-core/feedback-defaults.ts",
          "type": "registry:lib",
          "target": "@lib/feedback/feedback-defaults.ts"
        },
        {
          "path": "registry/screenshot-capture/capture.ts",
          "type": "registry:lib",
          "target": "@lib/feedback/capture.ts"
        },
        {
          "path": "registry/diagnostics/diagnostics.ts",
          "type": "registry:lib",
          "target": "@lib/feedback/diagnostics.ts"
        },
        {
          "path": "registry/scrub/scrub.ts",
          "type": "registry:lib",
          "target": "@lib/feedback/scrub.ts"
        }
      ]
    }
  ]
}
